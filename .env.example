# Copy this file to .env and fill in real values before deploying

ENV=production

# CHANGE THIS — minimum 32 random characters
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=dcuser
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=debugchamp
# Full DSN (auto-built by docker-compose from vars above; set manually for external DB)
# DATABASE_URL=postgresql://dcuser:change-me-db-password@db:5432/debugchamp

# ── Subdomain / CORS ─────────────────────────────────────────────────────────
# Replace debug.yourdomain.com with your actual subdomain
ALLOWED_ORIGINS=https://debug.yourdomain.com,http://debug.yourdomain.com
ALLOWED_HOSTS=debug.yourdomain.com

# Pytest runner timeout in seconds
PYTEST_TIMEOUT=60
