# Copy this file to .env and fill in real values before deploying

ENV=production

# CHANGE THIS — minimum 32 random characters
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost,http://localhost:80

# Allowed hosts (for TrustedHostMiddleware in production)
ALLOWED_HOSTS=localhost,127.0.0.1

# Pytest runner timeout in seconds
PYTEST_TIMEOUT=60
